# --- Core ---
GW_MASTER_KEY=change-me-to-a-long-random-string
# Optional explicit Fernet base key; if empty it is derived from MASTER_KEY.
GW_ENCRYPTION_KEY=
GW_DEBUG=false

# Console user sessions: how long a login token stays valid (hours). Users are
# created/managed by the master key (or another logged-in user) in the console.
GW_SESSION_TTL_HOURS=12

# --- Storage ---
# Default SQLite (single node). For production:
#   GW_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/llm_gateway
GW_DATABASE_URL=sqlite+aiosqlite:///./llm_gateway.db

# Optional Redis for cross-instance rate limiting + cache.
#   GW_REDIS_URL=redis://localhost:6379/0
GW_REDIS_URL=

# Auto-create tables on startup (zero-config dev). Set false in production and
# manage the schema with Alembic (`alembic upgrade head`). The Docker image's
# entrypoint runs migrations automatically.
GW_AUTO_CREATE_TABLES=true

# Whether the container entrypoint runs `alembic upgrade head` on start. Leave
# true for single-node / docker-compose. Set false on multi-replica (K8s) app
# pods and migrate once via a Job/initContainer (see deploy/k8s/).
GW_RUN_MIGRATIONS=true

# Connection pool (ignored for SQLite). Total upstream DB connections ≈
# replicas × (pool_size + max_overflow); keep under Postgres max_connections.
GW_DB_POOL_SIZE=10
GW_DB_MAX_OVERFLOW=20
GW_DB_POOL_TIMEOUT=30
GW_DB_POOL_RECYCLE=1800

# --- Proxy behaviour ---
GW_REQUEST_TIMEOUT=120
GW_MAX_RETRIES=2
GW_RETRY_BACKOFF_BASE=0.5

# Circuit breaker
GW_CB_FAILURE_THRESHOLD=5
GW_CB_COOLDOWN_SECONDS=30

# Cache (global default; per-alias overrides win)
GW_CACHE_ENABLED=false
GW_CACHE_TTL_SECONDS=300

# In-memory config snapshot TTL (how fast admin changes propagate)
GW_CONFIG_CACHE_TTL_SECONDS=5

# --- Observability ---
# Record the exact body sent to the provider and the raw upstream response in
# each request log (lets you verify param translation, e.g. reasoning level).
# Bodies include prompt content — set false if that's a privacy concern.
GW_LOG_UPSTREAM_IO=true
# Cap stored upstream response strings (chars; 0 = unlimited).
GW_LOG_UPSTREAM_MAX_CHARS=20000

# Write request logs off the request path (in-process queue + batching worker)
# to cut tail latency under load. Ignored for SQLite (always inline). A full
# queue drops the overflow log row (counted) rather than blocking a request.
GW_LOG_ASYNC=true
GW_LOG_QUEUE_MAX=10000
GW_LOG_BATCH_SIZE=100
GW_LOG_FLUSH_INTERVAL=0.5

# Expose Prometheus metrics at GET /metrics.
GW_METRICS_ENABLED=true
# Record mutating /admin calls (POST/PATCH/PUT/DELETE) to admin_audit_logs.
# Send an optional X-Admin-Actor header to label who made the change.
GW_ADMIN_AUDIT_ENABLED=true
# Emit per-request cost as the `x-litellm-response-cost` response header.
# litellm-based clients (e.g. dspy.LM) forward it into _hidden_params, so cost
# flows into downstream tracing (Opik etc.) with no client change. Set false to
# avoid revealing your cost basis to API callers.
GW_COST_HEADER_ENABLED=true

# Background sweep (seconds) that resets idle keys' daily/monthly budget
# windows. 0 disables it (on-access reset still happens). Multi-replica: every
# pod runs this; it's idempotent, but you may set it on just one if preferred.
GW_BUDGET_SWEEP_INTERVAL=300
