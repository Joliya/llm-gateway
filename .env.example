# --- Core ---
GW_MASTER_KEY=change-me-to-a-long-random-string
# Optional explicit Fernet base key; if empty it is derived from MASTER_KEY.
GW_ENCRYPTION_KEY=
GW_DEBUG=false

# --- Storage ---
# Default SQLite (single node). For production:
#   GW_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/llm_gateway
GW_DATABASE_URL=sqlite+aiosqlite:///./llm_gateway.db

# Optional Redis for cross-instance rate limiting + cache.
#   GW_REDIS_URL=redis://localhost:6379/0
GW_REDIS_URL=

# Auto-create tables on startup (zero-config dev). Set false in production and
# manage the schema with Alembic (`alembic upgrade head`). The Docker image's
# entrypoint runs migrations automatically.
GW_AUTO_CREATE_TABLES=true

# --- Proxy behaviour ---
GW_REQUEST_TIMEOUT=120
GW_MAX_RETRIES=2
GW_RETRY_BACKOFF_BASE=0.5

# Circuit breaker
GW_CB_FAILURE_THRESHOLD=5
GW_CB_COOLDOWN_SECONDS=30

# Cache (global default; per-alias overrides win)
GW_CACHE_ENABLED=false
GW_CACHE_TTL_SECONDS=300

# In-memory config snapshot TTL (how fast admin changes propagate)
GW_CONFIG_CACHE_TTL_SECONDS=5

# --- Observability ---
# Record the exact body sent to the provider and the raw upstream response in
# each request log (lets you verify param translation, e.g. reasoning level).
# Bodies include prompt content — set false if that's a privacy concern.
GW_LOG_UPSTREAM_IO=true
# Cap stored upstream response strings (chars; 0 = unlimited).
GW_LOG_UPSTREAM_MAX_CHARS=20000
